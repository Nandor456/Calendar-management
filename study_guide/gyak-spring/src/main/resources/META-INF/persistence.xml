<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             version="3.0"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="mypersistance" transaction-type="RESOURCE_LOCAL">

        <!-- Your entity classes -->
        <class>edu.mnim2377.gyak_spring.data.User</class>
        <class>edu.mnim2377.gyak_spring.data.Comment</class>


        <properties>
            <!-- JDBC connection -->
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5436/idde_db_gyak"/>
            <property name="jakarta.persistence.jdbc.user" value="idde_user_gyak"/>
            <property name="jakarta.persistence.jdbc.password" value="idde_password_gyak"/>

            <!-- Hibernate dialect -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>

            <!-- Schema generation -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>

            <!-- Show SQL (optional, useful for debugging) -->
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>
